// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// NextAuth.js Models (Auth.js)
// ==========================================

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  role          Role      @default(DOCTOR)
  accounts      Account[]
  sessions      Session[]
  appointments  Appointment[]
  evolutions    ClinicalEvolution[]
  suggestions   Suggestion[]
  loginLogs     LoginLog[]

  @@map("users")
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("login_logs")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Role {
  SUPERADMIN
  ADMIN
  DOCTOR
  ASSISTANT
}

// ==========================================
// ERP Models
// ==========================================

model Branch {
  id          String   @id @default(cuid())
  name        String
  address     String?
  phone       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patients    Patient[]
  appointments Appointment[]
  budgets     Budget[]
  payments    Payment[]

  @@map("branches")
}

model Patient {
  id              String        @id @default(cuid())
  firstName       String
  lastName        String
  dni             String        @unique
  phone           String?
  email           String?
  birthDate       DateTime?
  allergies       String?       @db.Text
  medicalHistory  String?       @db.Text
  isActive        Boolean       @default(true) // Soft Delete
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  branchId        String?
  branch          Branch?       @relation(fields: [branchId], references: [id])

  appointments    Appointment[]
  odontograms     Odontogram[]
  transactions    Transaction[]
  budgets         Budget[]
  evolutions      ClinicalEvolution[]

  @@map("patients")
}

model Appointment {
  id            String   @id @default(cuid())
  date          DateTime
  durationMins  Int      @default(30)
  status        AppointmentStatus @default(SCHEDULED)
  googleEventId String?
  notes         String?  @db.Text
  isActive      Boolean  @default(true) // Soft Delete
  
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  userId        String
  doctor        User     @relation(fields: [userId], references: [id])

  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("appointments")
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Odontogram {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  data      Json     // Estado gráfico de las piezas
  createdAt DateTime @default(now())

  @@map("odontograms")
}

// ----------------------
// HISTORIA CLÍNICA (EVOLUCIONES)
// ----------------------

model ClinicalEvolution {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId      String
  doctor      User     @relation(fields: [userId], references: [id])
  
  date        DateTime @default(now())
  treatment   String   // Nombre general del tratamiento realizado
  notes       String   @db.Text
  attachments Json?    // URLs de radiografías, fotos, etc.
  materials   EvolutionMaterial[] // Insumos deducidos
  isActive    Boolean  @default(true) // Soft Delete

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("clinical_evolutions")
}

// ----------------------
// MÓDULO DE PRESUPUESTOS Y FINANZAS
// ----------------------

model Treatment {
  id           String   @id @default(cuid())
  name         String
  category     String   
  defaultPrice Float    
  scope        String   
  isActive     Boolean  @default(true) // Soft Delete
  
  budgetItems  BudgetItem[]
}

model Budget {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])

  total       Float    // Total cotizado
  paidAmount  Float    @default(0) // Total amortizado/pagado
  
  status      String   @default("PENDING") // PENDING, PARTIAL, PAID, CANCELLED
  notes       String?
  isActive    Boolean  @default(true) // Soft Delete
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       BudgetItem[]
  payments    Payment[]

  @@map("budgets")
}

model BudgetItem {
  id          String   @id @default(cuid())
  budgetId    String
  budget      Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  treatmentId String
  treatment   Treatment @relation(fields: [treatmentId], references: [id])
  price       Float    
  toothNumber Int?     
  toothFace   String?  
  isActive    Boolean  @default(true)

  @@map("budget_items")
}

model Payment {
  id          String   @id @default(cuid())
  budgetId    String
  budget      Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])

  amount      Float    // Monto amortizado en esta transacción
  method      String   // Efectivo, Tarjeta, Transferencia
  date        DateTime @default(now())
  
  transactionId String? @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  isActive    Boolean  @default(true) // Soft Delete - Anular pago
  createdAt   DateTime @default(now())

  @@map("payments")
}

model Transaction {
  id          String   @id @default(cuid())
  type        TransactionType
  amount      Decimal  @db.Decimal(10, 2)
  description String
  date        DateTime @default(now())
  isActive    Boolean  @default(true) // Soft Delete
  
  patientId   String?
  patient     Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  payment     Payment?

  createdAt   DateTime @default(now())
  
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

// ----------------------
// MÓDULO DE INVENTARIO
// ----------------------

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  category    String   // MEDICAMENTO, INSUMO, HERRAMIENTA
  unit        String   // UNIDADES, CAJAS, MILILITROS
  stock       Float    @default(0)
  minStock    Float    @default(5)
  cost        Float    @default(0) // Costo por unidad
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  materialsUsed EvolutionMaterial[]

  @@map("inventory_items")
}

model EvolutionMaterial {
  id              String            @id @default(cuid())
  evolutionId     String
  evolution       ClinicalEvolution @relation(fields: [evolutionId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem     @relation(fields: [inventoryItemId], references: [id])
  quantity        Float             @default(1)

  @@map("evolution_materials")
}

// ----------------------
// MÓDULO DE SUGERENCIAS / FEEDBACK
// ----------------------

model Suggestion {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String   @db.Text
  response  String?  @db.Text
  status    String   @default("PENDING") // PENDING, RESOLVED
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("suggestions")
}
